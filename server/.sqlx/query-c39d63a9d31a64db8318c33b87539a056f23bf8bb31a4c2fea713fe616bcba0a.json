  "query": "\n        SELECT r.user_id, u.username as \"username!\"\n        FROM refresh_tokens r\n        INNER JOIN users u ON u.id = r.user_id\n        WHERE r.token_hash = $1 AND r.expires_at > NOW()\n        ",
